# FreeVi environment template
# Copy this file to .env and fill the API keys / overrides.
# The real .env should NOT be committed to git.

# Pexels API Key (required to download stock videos)
# Get a free key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional: Ollama server URL (if not running on default)
# Example: http://localhost:11434
# Leave empty to use the default Ollama client behavior
OLLAMA_HOST=

# Optional: Path to Kokoro model directory (relative or absolute)
# Default is ./kokoro-v1.0
KOKORO_MODEL_DIR=kokoro-v1.0
